root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.{java,kt}]
indent_size = 4

[*.{xml,json,yml,yaml}]
indent_size = 4

[*.md]
trim_trailing_whitespace = false

[*.gradle]
indent_size = 4

[*.{pro,properties}]
indent_size = 4
